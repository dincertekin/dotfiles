{
  "autosave": "on_focus_change",
  "base_keymap": "VSCode",
  "format_on_save": "on",
  "session": {
    "trust_all_worktrees": true,
  },
  "soft_wrap": "editor_width",
  "vim_mode": false,
  "buffer_font_size": 15,
  "colorize_brackets": true,
  "icon_theme": {
    "dark": "Colored Zed Icons Theme Dark",
    "light": "Colored Zed Icons Theme Light",
    "mode": "system",
  },
  "minimap": {
    "show": "never",
  },
  "tabs": {
    "close_position": "left",
    "file_icons": true,
  },
  "theme": {
    "dark": "GitHub Dark Dimmed",
    "light": "GitHub Light",
    "mode": "system",
  },
  "ui_font_size": 16,
  "collaboration_panel": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "project_panel": {
    "dock": "left",
  },
  "agent": {
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "model": "claude-sonnet-4-6",
      "provider": "zed.dev",
    },
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
    "sidebar_side": "right",
  },
  "disable_ai": false,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "profiles": {
    "Recording": {
      "settings": {
        "buffer_font_features": {
          "calt": false,
        },
        "buffer_font_size": 19,
        "theme": "One Dark Pro",
      },
    },
  },
}
